# -------------------------------------------------------
# Studio Video Processor — Environment Configuration
# -------------------------------------------------------
# Copy this file to .env and fill in your values.
# The application reads .env automatically on startup.
# -------------------------------------------------------

# Which AI provider to use for transcript summarization.
# Options: azure | openai | openai_compatible | ollama_local | ollama_cloud
# Leave blank to auto-detect Azure when AZURE_OPENAI_ENDPOINT is set.
AI_PROVIDER=azure

# -------------------------------------------------------
# Generic OpenAI-compatible settings
# Used by: openai, openai_compatible, ollama_local, ollama_cloud
# -------------------------------------------------------
# Base URL of the API (without trailing slash). Examples:
#   OpenAI:          https://api.openai.com/v1
#   Ollama local:    http://localhost:11434/v1
#   Ollama cloud:    https://ollama.com/v1
#   LM Studio:       http://localhost:1234/v1
#   Groq:            https://api.groq.com/openai/v1
#   Together:        https://api.together.xyz/v1
#   OpenRouter:      https://openrouter.ai/api/v1
AI_BASE_URL=

# Model name to use (e.g. gpt-4o-mini, llama3.1, mixtral-8x7b-instruct)
AI_MODEL=

# API key / bearer token. Leave empty for ollama_local.
AI_API_KEY=

# -------------------------------------------------------
# Transcription provider (speech-to-text)
# Options: google | faster_whisper | gemma4_local
# -------------------------------------------------------
TRANSCRIPT_PROVIDER=google

# faster-whisper settings (used when TRANSCRIPT_PROVIDER=faster_whisper)
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto

# Gemma 4 local settings (used when TRANSCRIPT_PROVIDER=gemma4_local)
GEMMA_MODEL_ID=google/gemma-4-E2B-it
GEMMA_DEVICE=auto
GEMMA_MAX_NEW_TOKENS=512

# -------------------------------------------------------
# Azure OpenAI settings (used when AI_PROVIDER=azure)
# -------------------------------------------------------
# Azure OpenAI service endpoint (include trailing slash)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# The deployment name you created in Azure AI Studio
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# The underlying model name (informational, used for logging)
AZURE_OPENAI_MODEL_NAME=gpt-4o-mini

# API version — check Azure docs for the latest stable value
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Your Azure OpenAI API key (keep this secret, never commit .env)
AZURE_OPENAI_API_KEY=your-api-key-here
